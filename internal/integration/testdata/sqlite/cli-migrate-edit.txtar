# Seed the migration directory's atlas.sum.
atlas migrate hash

# A fake $EDITOR that rewrites its target file with a known marker.
exec chmod 755 fake-editor.sh
env EDITOR=./fake-editor.sh

# Argument validation.
! atlas migrate edit
stderr 'Error: accepts 1 arg\(s\), received 0'

! atlas migrate edit foo bar
stderr 'Error: accepts 1 arg\(s\), received 2'

# Edit by version prefix: single match → file is rewritten, sum revalidates.
atlas migrate edit 1
cmp migrations/1_first.sql expected-edited.sql
atlas migrate validate

# Edit by exact filename: sibling is untouched.
atlas migrate edit 2_second.sql
cmp migrations/2_second.sql expected-edited.sql
atlas migrate validate

# No match → error, no side effects.
! atlas migrate edit 99999999999999
stderr 'no migration files found matching'

# Remote (non-local) dirs are rejected.
! atlas migrate edit --dir mem://edit-test 1
stderr 'only supports local directories'

# Stale atlas.sum is rejected before the editor runs.
cp first.sql migrations/1_first.sql
atlas migrate hash
cp first_modified.sql migrations/1_first.sql
! atlas migrate edit 1
stdout 'You have a checksum error'
cmp migrations/1_first.sql first_modified.sql

-- fake-editor.sh --
#!/bin/sh
echo 'edited' > "$1"
-- migrations/1_first.sql --
CREATE TABLE `users` (`id` integer NOT NULL, PRIMARY KEY (`id`));
-- migrations/2_second.sql --
CREATE TABLE `pets` (`id` integer NOT NULL, PRIMARY KEY (`id`));
-- expected-edited.sql --
edited
-- first.sql --
CREATE TABLE `users` (`id` integer NOT NULL, PRIMARY KEY (`id`));
-- first_modified.sql --
CREATE TABLE `users` (`id` integer NOT NULL, `age` integer, PRIMARY KEY (`id`));
